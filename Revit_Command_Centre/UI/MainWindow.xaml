<Window x:Class="Revit_Command_Centre.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ps="clr-namespace:Revit_Command_Centre.Modules.ProjectSetup"
        xmlns:sh="clr-namespace:Revit_Command_Centre.Modules.SheetsAndDisciplines"
        xmlns:uf="clr-namespace:Revit_Command_Centre.Modules.UpdateFamilies"
        xmlns:cf="clr-namespace:Revit_Command_Centre.Modules.CreateFamilies"
        Title="BIM Command Centre"
        Width="680" MinHeight="600" MinWidth="680"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.Resources>
        <!-- Styles inlined from Styles.xaml — no pack URI / separate BAML load -->

        <!-- Colour palette -->
        <Color x:Key="PrimaryBlueColor">#185FA5</Color>
        <Color x:Key="LightBlueBgColor">#E6F1FB</Color>
        <Color x:Key="SidebarBgColor">#F8F8F8</Color>
        <Color x:Key="BorderColor">#1E000000</Color>
        <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
        <Color x:Key="TextSecondaryColor">#6B6B6B</Color>
        <Color x:Key="TextTertiaryColor">#9B9B9B</Color>
        <Color x:Key="SuccessGreenColor">#1D9E75</Color>
        <Color x:Key="WarningAmberColor">#BA7517</Color>
        <Color x:Key="DangerRedColor">#E24B4A</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush"    Color="{StaticResource PrimaryBlueColor}"/>
        <SolidColorBrush x:Key="LightBlueBgBrush"    Color="{StaticResource LightBlueBgColor}"/>
        <SolidColorBrush x:Key="SidebarBgBrush"      Color="{StaticResource SidebarBgColor}"/>
        <SolidColorBrush x:Key="BorderBrush_"        Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="TextTertiaryBrush"   Color="{StaticResource TextTertiaryColor}"/>
        <SolidColorBrush x:Key="SuccessGreenBrush"   Color="{StaticResource SuccessGreenColor}"/>
        <SolidColorBrush x:Key="WarningAmberBrush"   Color="{StaticResource WarningAmberColor}"/>
        <SolidColorBrush x:Key="DangerRedBrush"      Color="{StaticResource DangerRedColor}"/>

        <!-- Typography -->
        <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"      Value="0,2,0,0"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextTertiaryBrush}"/>
            <Setter Property="Margin"      Value="16,14,0,6"/>
        </Style>

        <!-- Sidebar navigation buttons -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"        Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="Normal"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"           Value="16,0,12,0"/>
            <Setter Property="Height"            Value="36"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="FontWeight"  Value="Medium"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background"  Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="{StaticResource PrimaryBlueBrush}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action buttons -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1450A0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3E80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Normal"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush_}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F4F4F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cards -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush_}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="14"/>
        </Style>

        <Style x:Key="CardSelectedStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Background"      Value="{StaticResource LightBlueBgBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PrimaryBlueBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Status / log -->
        <Style x:Key="LogEntryStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding"    Value="0,1"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════  SIDEBAR  ═══════════════ -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / app title -->
            <Border Grid.Row="0" Padding="16,18,16,14"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="BIM" FontFamily="{StaticResource AppFont}" FontSize="20"
                               FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}"/>
                    <TextBlock Text="Command Centre" FontFamily="{StaticResource AppFont}" FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <StackPanel Grid.Row="1" Margin="0,4,0,0">

                <!-- SETUP section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="SETUP"/>

                <Button x:Name="BtnProjectSetup"
                        Style="{StaticResource NavButtonActiveStyle}"
                        Click="NavButton_Click" Tag="ProjectSetup">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2630;" FontSize="13" Width="18" TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Project Setup" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSheets"
                        Style="{StaticResource NavButtonStyle}"
                        Click="NavButton_Click" Tag="Sheets">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x229E;" FontSize="13" Width="18" TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Sheets &amp; Disciplines" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- FAMILIES section -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="FAMILIES"/>

                <Button x:Name="BtnUpdateFamilies"
                        Style="{StaticResource NavButtonStyle}"
                        Click="NavButton_Click" Tag="UpdateFamilies">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x21BB;" FontSize="14" Width="18" TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Update Families" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnCreateFamilies"
                        Style="{StaticResource NavButtonStyle}"
                        Click="NavButton_Click" Tag="CreateFamilies">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2726;" FontSize="13" Width="18" TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Create Families" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Project chip (document selector) -->
            <Border Grid.Row="2" Margin="10,0,10,14" Padding="10,8"
                    Background="White" CornerRadius="6"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                    Cursor="Hand" MouseLeftButtonUp="ProjectChip_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="DocStatusDot" Grid.Column="0" Width="8" Height="8"
                             Fill="{StaticResource WarningAmberBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock x:Name="TxtDocumentName" Text="No document open"
                                   FontFamily="{StaticResource AppFont}" FontSize="11" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TxtProjectNumber" Text="—"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Sidebar border line -->
        <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush_}"/>

        <!-- ═══════════════  MAIN CONTENT  ═══════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Border Grid.Row="0" Padding="20,14"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="0,0,0,1"
                    Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtPageTitle"    Style="{StaticResource PageTitleStyle}"    Text="Project Setup"/>
                        <TextBlock x:Name="TxtPageSubtitle" Style="{StaticResource PageSubtitleStyle}" Text="Configure project information and compliance tier"/>
                    </StackPanel>

                    <StackPanel x:Name="TopbarButtons" Grid.Column="1"
                                Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- Scrollable content area — swapped by navigation -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#FAFAFA">
                <ContentControl x:Name="ContentArea"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

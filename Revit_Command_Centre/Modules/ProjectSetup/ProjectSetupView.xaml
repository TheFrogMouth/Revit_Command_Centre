<UserControl x:Class="Revit_Command_Centre.Modules.ProjectSetup.ProjectSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Revit_Command_Centre;component/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="20,16,20,24">

        <!-- ── TITLE BLOCK FOLDER ── -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="TITLE BLOCK FOLDER" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtTitleBlockFolder" Style="{StaticResource TextBoxStyle}"
                             IsReadOnly="True" Cursor="Hand"
                             MouseLeftButtonUp="BrowseTitleBlockFolder_Click"
                             ToolTip="Folder containing title block .rfa files."/>
                </StackPanel>
                <StackPanel x:Name="BrowseTitleBlockFolderContainer" Grid.Column="2"
                            Margin="0,18,0,0" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- ── CLIENT &amp; PROJECT INFO ── -->
        <TextBlock Text="CLIENT &amp; PROJECT INFO" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0">
                    <TextBlock Text="CLIENT NAME" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtClientName" Style="{StaticResource TextBoxStyle}"
                             TextChanged="Preview_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0">
                    <TextBlock x:Name="LblProjectName" Text="PROJECT NAME" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtProjectName" Style="{StaticResource TextBoxStyle}"
                             TextChanged="Preview_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="2">
                    <TextBlock x:Name="LblProjectNumber" Text="PROJECT NUMBER" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtProjectNumber" Style="{StaticResource TextBoxStyle}"
                             TextChanged="Preview_Changed"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="2">
                    <TextBlock Text="LANGUAGE" Style="{StaticResource LabelStyle}"/>
                    <StackPanel x:Name="CmbLanguage"/>
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="4">
                    <TextBlock Text="TITLE BLOCK" Style="{StaticResource LabelStyle}"/>
                    <StackPanel x:Name="CmbTitleBlock"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── COMPLIANCE TIER ── -->
        <TextBlock Text="COMPLIANCE TIER" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,10"/>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="CardTier1" Grid.Column="0" Style="{StaticResource CardStyle}"
                    Cursor="Hand" MouseLeftButtonUp="TierCard_Click" Tag="1">
                <StackPanel>
                    <TextBlock Text="Tier 1" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Standard" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Basic dimensions, materials, phase"/>
                </StackPanel>
            </Border>

            <Border x:Name="CardTier2" Grid.Column="2" Style="{StaticResource CardSelectedStyle}"
                    Cursor="Hand" MouseLeftButtonUp="TierCard_Click" Tag="2">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Tier 2" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="{StaticResource PrimaryBlueBrush}" CornerRadius="3"
                                Padding="5,1" Margin="6,0,0,0">
                            <TextBlock Text="DEFAULT" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="BIM Compliant" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="+ IFC4, Uniclass 2015, fire rating"/>
                </StackPanel>
            </Border>

            <Border x:Name="CardTier3" Grid.Column="4" Style="{StaticResource CardStyle}"
                    Cursor="Hand" MouseLeftButtonUp="TierCard_Click" Tag="3">
                <StackPanel>
                    <TextBlock Text="Tier 3" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="ISO 19650 Full" FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryBlueBrush}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="+ COBie, asset data, FM handover"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── TITLE BLOCK PREVIEW ── -->
        <TextBlock Text="TITLE BLOCK PREVIEW" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,10"/>

        <Border BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1"
                CornerRadius="6" Background="White" Padding="16,14" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="CLIENT"
                           Style="{StaticResource LabelStyle}" MinWidth="100"/>
                <TextBlock x:Name="PreviewClient" Grid.Column="1" Grid.Row="0"
                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Column="0" Grid.Row="2" Text="PROJECT"
                           Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="PreviewProject" Grid.Column="1" Grid.Row="2"
                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Column="0" Grid.Row="4" Text="PROJECT NR"
                           Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="PreviewNumber" Grid.Column="1" Grid.Row="4"
                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Column="0" Grid.Row="6" Text="LANGUAGE"
                           Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="PreviewLanguage" Grid.Column="1" Grid.Row="6"
                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Column="0" Grid.Row="8" Text="TIER"
                           Style="{StaticResource LabelStyle}"/>
                <TextBlock x:Name="PreviewTier" Grid.Column="1" Grid.Row="8"
                           FontSize="12" Foreground="{StaticResource PrimaryBlueBrush}" FontWeight="Medium"/>
            </Grid>
        </Border>

        <!-- ── WORKSETS ── -->
        <TextBlock Text="WORKSETS" Style="{StaticResource SectionHeaderStyle}" Margin="0,14,0,10"/>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="User worksets in this project" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel x:Name="WorksetActionContainer" Grid.Column="1"
                                Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel x:Name="WorksetsList"/>
                <TextBlock x:Name="TxtWorksetsStatus" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>

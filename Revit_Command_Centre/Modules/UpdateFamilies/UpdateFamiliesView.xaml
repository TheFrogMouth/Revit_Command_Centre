<UserControl x:Class="Revit_Command_Centre.Modules.UpdateFamilies.UpdateFamiliesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             AllowDrop="True"
             Drop="DropZone_Drop"
             DragOver="DropZone_DragOver">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Revit_Command_Centre;component/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="20,16,20,24">

        <!-- ── DROP ZONE ── -->
        <Border x:Name="DropZoneBorder" Height="110" CornerRadius="8"
                BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="2"
                Background="{StaticResource LightBlueBgBrush}"
                Margin="0,0,0,14" Cursor="Hand"
                MouseLeftButtonUp="DropZone_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x2913;" FontSize="28" HorizontalAlignment="Center"
                           Foreground="{StaticResource PrimaryBlueBrush}"/>
                <TextBlock Text="Drop a folder of .rfa files here, or click to browse"
                           FontSize="12" Foreground="{StaticResource PrimaryBlueBrush}"
                           Margin="0,6,0,0" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtSelectedFolder" Text=""
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0" HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="380"/>
            </StackPanel>
        </Border>

        <!-- ── FILTERS ── -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CATEGORY FILTER" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="CmbCategoryFilter" Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Architectural"/>
                        <ComboBoxItem Content="Structural"/>
                        <ComboBoxItem Content="MEP"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="APPLY PARAMETERS" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="CmbParameterFilter" Style="{StaticResource ComboBoxStyle}">
                        <ComboBoxItem Content="From project config" IsSelected="True"/>
                        <ComboBoxItem Content="Tier 1 only"/>
                        <ComboBoxItem Content="All tiers"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── PROGRESS ── -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtCurrentFile" Grid.Column="0"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Ready" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtProgress" Grid.Column="1"
                               FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="8,0,0,0"/>
                </Grid>
                <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                             Foreground="{StaticResource PrimaryBlueBrush}"
                             Background="#E0E0E0" Value="0"/>
            </StackPanel>
        </Border>

        <!-- ── STATS ── -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="StatTotal" Text="0" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="StatUpdated" Text="0" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessGreenBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Updated" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="StatSkipped" Text="0" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource WarningAmberBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Skipped" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock x:Name="StatErrors" Text="0" FontSize="22" FontWeight="SemiBold"
                               Foreground="{StaticResource DangerRedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Errors" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── LOG PANEL ── -->
        <TextBlock Text="LOG" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
        <Border Style="{StaticResource CardStyle}" MinHeight="140">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                <StackPanel x:Name="LogPanel"/>
            </ScrollViewer>
        </Border>

    </StackPanel>
</UserControl>

<UserControl x:Class="Revit_Command_Centre.Modules.SheetsAndDisciplines.SheetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Revit_Command_Centre;component/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="20,16,20,24">

        <!-- ── ACTIVE DISCIPLINES ── -->
        <TextBlock Text="ACTIVE DISCIPLINES" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>

        <WrapPanel x:Name="DisciplinesPanel" Margin="0,0,0,16">
            <!-- Discipline toggle cards are generated in code-behind -->
        </WrapPanel>

        <!-- ── SHEET NAMING CONVENTION ── -->
        <TextBlock Text="SHEET NAMING CONVENTION" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,10"/>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Format -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="FORMAT" Style="{StaticResource LabelStyle}"/>
                    <!-- Picker built in code-behind — no WPF ComboBox ControlTemplate -->
                    <StackPanel x:Name="CmbFormat"/>
                </StackPanel>

                <!-- Number padding -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="NUMBER PADDING" Style="{StaticResource LabelStyle}"/>
                    <StackPanel x:Name="CmbPadding"/>
                </StackPanel>

                <!-- Separator -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="SEPARATOR" Style="{StaticResource LabelStyle}"/>
                    <StackPanel x:Name="CmbSeparator"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── SHEET LIST PREVIEW ── -->
        <TextBlock Text="SHEET LIST PREVIEW" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,10"/>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <!-- Header row -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SHEET CODE" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Column="1" Text="SHEET NAME"  Style="{StaticResource LabelStyle}"/>
                </Grid>
                <Rectangle Fill="{StaticResource BorderBrush_}" Height="1" Margin="0,0,0,8"/>

                <!-- Generated preview rows -->
                <ItemsControl x:Name="PreviewList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Code}"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="{StaticResource PrimaryBlueBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="TxtNoPreview" Text="Enable at least one discipline to see the preview."
                           FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,4,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

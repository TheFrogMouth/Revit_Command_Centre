<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════  COLOUR PALETTE  ══════════════════════ -->
    <Color x:Key="PrimaryBlueColor">#185FA5</Color>
    <Color x:Key="LightBlueBgColor">#E6F1FB</Color>
    <Color x:Key="SidebarBgColor">#F8F8F8</Color>
    <Color x:Key="BorderColor">#1E000000</Color>
    <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#6B6B6B</Color>
    <Color x:Key="TextTertiaryColor">#9B9B9B</Color>
    <Color x:Key="SuccessGreenColor">#1D9E75</Color>
    <Color x:Key="WarningAmberColor">#BA7517</Color>
    <Color x:Key="DangerRedColor">#E24B4A</Color>

    <SolidColorBrush x:Key="PrimaryBlueBrush"    Color="{StaticResource PrimaryBlueColor}"/>
    <SolidColorBrush x:Key="LightBlueBgBrush"    Color="{StaticResource LightBlueBgColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush"      Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush_"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"   Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="SuccessGreenBrush"   Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="WarningAmberBrush"   Color="{StaticResource WarningAmberColor}"/>
    <SolidColorBrush x:Key="DangerRedBrush"      Color="{StaticResource DangerRedColor}"/>

    <!-- ══════════════════════  TYPOGRAPHY  ══════════════════════ -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="14"/>
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin"      Value="0,2,0,0"/>
    </Style>

    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="10"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextTertiaryBrush}"/>
        <Setter Property="Margin"      Value="16,14,0,6"/>
    </Style>

    <!-- ══════════════════════  INPUT CONTROLS  ══════════════════════ -->
    <Style x:Key="TextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily"       Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"         Value="12"/>
        <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"       Value="White"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush_}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="8,6"/>
        <Setter Property="Height"           Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush_}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,0"/>
        <Setter Property="Height"          Value="32"/>
    </Style>

    <!-- ══════════════════════  SIDEBAR NAVIGATION  ══════════════════════ -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"        Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="Normal"/>
        <Setter Property="Foreground"        Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Background"        Value="Transparent"/>
        <Setter Property="BorderThickness"   Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"           Value="16,0,12,0"/>
        <Setter Property="Height"            Value="36"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#F0F0F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"  Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource PrimaryBlueBrush}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════  ACTION BUTTONS  ══════════════════════ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="Medium"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Background"      Value="{StaticResource PrimaryBlueBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1450A0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#0F3E80"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="Normal"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush_}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F4F4F4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══════════════════════  CARD / TILE  ══════════════════════ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush_}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="14"/>
    </Style>

    <Style x:Key="CardSelectedStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background"      Value="{StaticResource LightBlueBgBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource PrimaryBlueBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- ══════════════════════  STATUS INDICATORS  ══════════════════════ -->
    <Style x:Key="LogEntryStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding"    Value="0,1"/>
    </Style>

    <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="MinWidth" Value="90"/>
    </Style>

</ResourceDictionary>
